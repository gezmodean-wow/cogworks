<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

    <!--
        Cogworks-1.0 load manifest. Consumer cogs reference this single file
        from their .toc; it pulls in the library entry point and the per-area
        modules (Items, Realms, ...) in dependency order.

        Consumer .toc snippet:
            Libs\Cogworks-1.0\Cogworks-1.0.xml
    -->

    <Script file="Cogworks-1.0.lua" />
    <Script file="Items.lua" />
    <Script file="Realms.lua" />
    <Script file="API.lua" />

</Ui>
